@{
    ViewData["Title"] = "ViewVenue";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Venues</h2>
        <a class="btn btn-primary" asp-controller="Home" asp-action="CreateVenue">Report New Venue</a>
    </div>

    <table id="listTable" class="display nowrap table table-striped table-bordered" style="width:100%">
        <thead class="table-dark">
            <tr>
                <th>Venue Name</th>
                <th>Location</th>
                <th>Capacity</th>
                <th>Image</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (ViewBag.Venues != null && (ViewBag.Venues as List<Dictionary<string, object>>).Count > 0)
            {
                foreach (var venue in ViewBag.Venues as List<Dictionary<string, object>>)
                {
                    <tr>
                        <td>@(venue["VenueName"] ?? "")</td>
                        <td>@(venue["Location"] ?? "")</td>
                        <td>@(venue["Capacity"]?.ToString() ?? "")</td>
                        <td>
                            <img src="@(venue["ImageUrl"] ?? "/Images/default.png")"
                                 alt="Venue Image"
                                 style="height:50px; width:auto;"
                                 class="img-thumbnail" />
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-danger"
                               asp-controller="Home"
                               asp-action="DeleteVenue"
                               asp-route-id="@(venue["VenueId"])">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No records found</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#listTable').DataTable({
                dom: 'Bfrtip',
                buttons: ['copy', 'csv', 'excel', 'pdf', 'print'],
                scrollX: true,
                ordering: true,
                info: true,
                paging: true,
                order: [[0, 'desc']]
            });
        });
    </script>
}
